# Server-side OpenAI key used by /.netlify/functions/ai
OPENAI_API_KEY=

# Auth provider selection
VITE_AUTH_PROVIDER=netlify

# Invite-only Netlify Identity defaults
# VITE_NETLIFY_SITE_URL=
# VITE_NETLIFY_IDENTITY_LOCALE=en

# Optional auth UX flags
# VITE_AUTH_LOGIN_REDIRECT_PATH=/
# VITE_AUTH_LOGOUT_REDIRECT_PATH=/
# VITE_AUTH_DEBUG=false

VITE_NETLIFY_SITE_URL=https://your-site-name.netlify.app
VITE_NETLIFY_PUBLIC_SIGNUP=false
VITE_AUTH_LOGIN_REDIRECT_PATH=/
VITE_AUTH_LOGOUT_REDIRECT_PATH=/
